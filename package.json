{
  "name": "events-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3003",
    "build": "next build",
    "start": "next start -p 3003",
    "lint": "next lint",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "db:seed": "dotenv -e .env.local -- npx tsx lib/db/seed.ts",
    "db:cleanup": "dotenv -e .env.local -- npx tsx lib/db/cleanup-non-thailand.ts",
    "db:backfill-venues": "dotenv -e .env.local -- npx tsx lib/db/backfill-venues.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@base-ui/react": "^1.3.0",
    "@fal-ai/client": "^1.9.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "firecrawl": "^1.21.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "dotenv-cli": "^11.0.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
